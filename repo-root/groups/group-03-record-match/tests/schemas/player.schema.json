{
  "$id": "https://five.example.org/schemas/player.schema.json",
  "title": "Player",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "firstName": {
      "type": "string",
      "minLength": 1
    },
    "lastName": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["id", "firstName", "lastName"],
  "additionalProperties": false
}
