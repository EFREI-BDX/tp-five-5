{
  "$id": "https://five.example.org/schemas/team.schema.json",
  "title": "Team",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "tag": {
      "type": "string",
      "pattern": "^[A-Z0-9]{3}$"
    }
  },
  "required": ["id", "tag"],
  "additionalProperties": false
}
