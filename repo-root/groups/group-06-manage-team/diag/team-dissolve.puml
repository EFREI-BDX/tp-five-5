@startuml
' Diag de séquence pour PUT /api/teams/{id}/dissolve
' Jacobson, PlantUML v2
actor Client
boundary TeamController
control TeamService
entity TeamRepository
entity TeamMapper
control TeamEventOutboundService

Client -> TeamController : dissolve(id, dissolutionDate)
TeamController -> TeamService : executeCommand(TeamDissolveCommand)
TeamService -> TeamRepository : dissolve(...)
TeamRepository --> TeamService : PersistenceOperationResult
TeamService -> TeamRepository : findById(id)
TeamRepository --> TeamService : TeamEntity
TeamService -> TeamMapper : entityToDto(TeamEntity)
TeamMapper --> TeamService : TeamDto
TeamService -> TeamEventOutboundService : notifyTeamDissolve(TeamDto)
TeamEventOutboundService ->> ExternalApp : POST /api/integration/teams/delete
TeamService --> TeamController : TeamDto
TeamController --> Client : ResponseEntity<TeamDto>
@enduml

