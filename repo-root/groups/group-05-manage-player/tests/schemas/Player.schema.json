{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "firstName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "lastName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "email": {
      "type": "string",
      "format": "email"
    },
    "phone": {
      "type": "string",
      "pattern": "^(\\+33|0)[1-9]([0-9]{8}|[0-9\\s.\\-]{8,})$"
    },
    "gender": {
      "type": "string",
      "enum": ["homme", "femme", "non binaire", "non spécifié"]
    },
    "birthDate": {
      "type": "string",
      "pattern": "^(0[1-9]|[12][0-9]|3[01])/(0[1-9]|1[0-2])/[0-9]{4}$"
    },
    "height": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "teamIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "statistics": {
      "type": "object",
      "properties": {
        "matchesPlayed": { "type": "integer", "minimum": 0 },
        "goalsScored": { "type": "integer", "minimum": 0 },
        "assists": { "type": "integer", "minimum": 0 },
        "wins": { "type": "integer", "minimum": 0 },
        "draws": { "type": "integer", "minimum": 0 },
        "mvps": { "type": "integer", "minimum": 0 }
      },
      "required": ["matchesPlayed", "goalsScored", "assists", "wins", "draws", "mvps"]
    },
    "status": {
      "type": "string",
      "enum": ["actif", "inactif", "supprimé"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "firstName", "lastName", "email", "phone", "gender", "birthDate", "height", "statistics", "status", "createdAt", "updatedAt"],
  "additionalProperties": false
}
