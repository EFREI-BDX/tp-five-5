{
  "$id": "https://example.org/schemas/field-created.schema.json",
  "title": "FieldCreated",
  "type": "object",
  "properties": {
    "fieldId": {
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "maintenance",
        "unavailable"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "fieldId",
    "name",
    "status",
    "timestamp",
    "traceId"
  ],
  "additionalProperties": false
}
