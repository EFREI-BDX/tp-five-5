{
  "$id": "https://example.org/schemas/match-recorded.schema.json",
  "title": "MatchRecorded",
  "type": "object",
  "properties": {
    "matchId": {
      "type": "string",
      "format": "uuid"
    },
    "fieldId": {
      "type": "string",
      "format": "uuid"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "endedAt": {
      "type": "string",
      "format": "date-time"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "matchId",
    "fieldId",
    "startedAt",
    "endedAt",
    "timestamp",
    "traceId"
  ],
  "additionalProperties": false
