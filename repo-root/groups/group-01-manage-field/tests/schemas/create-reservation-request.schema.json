{
  "$id": "https://example.org/schemas/create-reservation-request.schema.json",
  "title": "CreateReservationRequest",
  "description": "Same-day reservation request. Allowed durations are 60, 90, or 120 minutes.",
  "type": "object",
  "properties": {
    "status_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "date": {
      "$ref": "./time-slot.schema.json#/definitions/date"
    },
    "start_time": {
      "$ref": "./time-slot.schema.json#/definitions/start_time"
    },
    "end_time": {
      "$ref": "./time-slot.schema.json#/definitions/end_time"
    }
  },
  "required": [
    "status_id",
    "date",
    "start_time",
    "end_time"
  ],
  "allOf": [
    {
      "$ref": "./time-slot.schema.json#/definitions/duration_rules"
    }
  ],
  "additionalProperties": false
}
