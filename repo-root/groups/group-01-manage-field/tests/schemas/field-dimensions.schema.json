{
  "$id": "https://example.org/schemas/field-dimensions.schema.json",
  "title": "FieldDimensions",
  "type": "object",
  "$comment": "Business rule enforced in domain code: lengthMeters must be strictly greater than widthMeters.",
  "properties": {
    "lengthMeters": {
      "type": "integer",
      "minimum": 25,
      "maximum": 50
    },
    "widthMeters": {
      "type": "integer",
      "minimum": 15,
      "maximum": 35
    }
  },
  "required": [
    "lengthMeters",
    "widthMeters"
  ],
  "additionalProperties": false
}
