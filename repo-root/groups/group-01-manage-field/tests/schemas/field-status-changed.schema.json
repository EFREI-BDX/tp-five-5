{
  "$id": "https://example.org/schemas/field-status-changed.schema.json",
  "title": "FieldStatusChanged",
  "type": "object",
  "properties": {
    "fieldId": {
      "type": "string",
      "format": "uuid"
    },
    "previousStatus": {
      "type": "string",
      "enum": [
        "active",
        "maintenance",
        "unavailable"
      ]
    },
    "newStatus": {
      "type": "string",
      "enum": [
        "active",
        "maintenance",
        "unavailable"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "fieldId",
    "previousStatus",
    "newStatus",
    "timestamp",
    "traceId"
  ],
  "additionalProperties": false
}
