@startuml
|Match Management (Group 02)|
start
:Choisir date/heure et terrain cible;
:Appeler GET /fields/{fieldId}/availability;

|Field Management (Group 01)|
:Valider format de la requete;
:Verifier statut terrain + conflits de reservation;
if (Terrain reservable?) then (oui)
  :Retourner disponibilite positive;
  |Match Management (Group 02)|
  :Appeler POST /fields/{fieldId}/reservations;
  |Field Management (Group 01)|
  :Creer reservation;
  :Publier FieldReservationCreated;
  :Repondre 201 + reservationId;
else (non)
  :Retourner 409 (slot indisponible);
endif
stop
@enduml
