{
  "serviceId": "group-01-field-management",
  "name": "Field Management",
  "version": "2.0.0",
  "description": "Source-of-truth service for fields, their statuses, and reservations.",
  "owner": {
    "team": "group-01-manage-field",
    "contact": "todo@example.org"
  },
  "repository": {
    "type": "git",
    "url": "git@example.org:school/jadtpddd.git",
    "path": "repo-root/groups/group-01-manage-field"
  },
  "endpoints": [
    {
      "path": "/v1/field-statuses",
      "method": "GET",
      "operationId": "listFieldStatuses",
      "responseSchema": "./tests/schemas/field-status-list.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/reservation-statuses",
      "method": "GET",
      "operationId": "listReservationStatuses",
      "responseSchema": "./tests/schemas/reservation-status-list.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields",
      "method": "POST",
      "operationId": "createField",
      "requestSchema": "./openapi.yaml#/components/schemas/CreateFieldRequest",
      "responseSchema": "./tests/schemas/field.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields/available",
      "method": "GET",
      "operationId": "listAvailableFields",
      "responseSchema": "./tests/schemas/field-list.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields/{field_id}",
      "method": "GET",
      "operationId": "getField",
      "responseSchema": "./tests/schemas/field.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields/{field_id}/status",
      "method": "PATCH",
      "operationId": "updateFieldStatus",
      "requestSchema": "./openapi.yaml#/components/schemas/UpdateFieldStatusRequest",
      "responseSchema": "./tests/schemas/field.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields/{field_id}/reservations",
      "method": "POST",
      "operationId": "createReservation",
      "requestSchema": "./openapi.yaml#/components/schemas/CreateReservationRequest",
      "responseSchema": "./tests/schemas/reservation.schema.json",
      "auth": "ApiKeyAuth"
    },
    {
      "path": "/v1/fields/{field_id}/reservations/{reservation_id}/status",
      "method": "PATCH",
      "operationId": "updateReservationStatus",
      "requestSchema": "./openapi.yaml#/components/schemas/UpdateReservationStatusRequest",
      "responseSchema": "./tests/schemas/reservation.schema.json",
      "auth": "ApiKeyAuth"
    }
  ],
  "eventsProduced": [
    {
      "name": "FieldCreated",
      "schema": "./tests/schemas/field-created.event.schema.json"
    },
    {
      "name": "FieldStatusChanged",
      "schema": "./tests/schemas/field-status-changed.event.schema.json"
    },
    {
      "name": "ReservationCreated",
      "schema": "./tests/schemas/reservation-created.event.schema.json"
    },
    {
      "name": "ReservationStatusChanged",
      "schema": "./tests/schemas/reservation-status-changed.event.schema.json"
    }
  ],
  "eventsConsumed": [],
  "schemas": [
    "./tests/schemas/id.schema.json",
    "./tests/schemas/field-name.schema.json",
    "./tests/schemas/field-status-code.schema.json",
    "./tests/schemas/reservation-status-code.schema.json",
    "./tests/schemas/time-slot.schema.json",
    "./tests/schemas/create-reservation-request.schema.json",
    "./tests/schemas/field-list.schema.json",
    "./tests/schemas/field-status-list.schema.json",
    "./tests/schemas/reservation-status-list.schema.json",
    "./tests/schemas/field-status.schema.json",
    "./tests/schemas/reservation-status.schema.json",
    "./tests/schemas/field.schema.json",
    "./tests/schemas/reservation.schema.json"
  ],
  "health": {
    "path": "/health",
    "method": "GET",
    "expectedStatus": 200
  },
  "security": {
    "type": "apiKey",
    "in": "header",
    "name": "X-API-KEY"
  },
  "metadata": {
    "schemaVersion": "1.0",
    "lastUpdated": "2026-03-30"
  }
}
