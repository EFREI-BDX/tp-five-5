{
  "info": {
    "name": "Group 01 - Manage Field API",
    "description": "Mock collection pour tester le service de gestion des terrains.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Fields",
      "item": [
        {
          "name": "Create Field",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Field A\",\n  \"venueName\": \"Arena Central\",\n  \"address\": \"10 rue du Five, Paris\",\n  \"surface\": {\n    \"surface\": \"synthetic_turf\"\n  }\n}"
            }
          }
        },
        {
          "name": "List Fields",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields?status=active",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                }
              ]
            }
          }
        },
        {
          "name": "Get Field",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields/{{fieldId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields",
                "{{fieldId}}"
              ]
            }
          }
        },
        {
          "name": "Update Field Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields/{{fieldId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields",
                "{{fieldId}}",
                "status"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"maintenance\",\n  \"reason\": \"weekly floor check\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Get Availability",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields/{{fieldId}}/availability?from=2026-03-10T18:00:00Z&to=2026-03-10T20:00:00Z",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields",
                "{{fieldId}}",
                "availability"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "2026-03-10T18:00:00Z"
                },
                {
                  "key": "to",
                  "value": "2026-03-10T20:00:00Z"
                }
              ]
            }
          }
        },
        {
          "name": "Create Reservation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields/{{fieldId}}/reservations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields",
                "{{fieldId}}",
                "reservations"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"matchId\": \"d58f5983-7f31-409d-a95f-b5d29f2b83d2\",\n  \"slot\": {\n    \"startAt\": \"2026-03-10T18:00:00Z\",\n    \"endAt\": \"2026-03-10T19:00:00Z\"\n  },\n  \"requestedByService\": \"group-02-manage-match\"\n}"
            }
          }
        },
        {
          "name": "Release Reservation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{apiKey}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fields/{{fieldId}}/reservations/{{reservationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fields",
                "{{fieldId}}",
                "reservations",
                "{{reservationId}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.example.org"
    },
    {
      "key": "apiKey",
      "value": "dev-key"
    },
    {
      "key": "fieldId",
      "value": "123e4567-e89b-12d3-a456-426614174000"
    },
    {
      "key": "reservationId",
      "value": "7ab57fb4-ac26-44ca-bf2b-5452e13e11aa"
    }
  ]
}
